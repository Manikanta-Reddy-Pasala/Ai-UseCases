# Anthropic API Key (required for real mode, optional for demo mode)
ANTHROPIC_API_KEY=sk-ant-xxxx

# Mode: "real" uses Claude API, "demo" uses mock responses
AGENT_MODE=demo

# Model to use
CLAUDE_MODEL=claude-sonnet-4-20250514

# Server config
HOST=0.0.0.0
PORT=8000

# Redis (optional - falls back to in-memory if unavailable)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=INFO
